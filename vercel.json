{
    "version": 2,
    "builds": [
        {
            "src": "api/index.js",
            "use": "@vercel/node"
        },
        {
            "src": "web/package.json",
            "use": "@vercel/next"
        }
    ],
    "routes": [
        {
            "src": "/api/services(.*)",
            "dest": "/api/index.js"
        },
        {
            "src": "/api/projects(.*)",
            "dest": "/api/index.js"
        },
        {
            "src": "/api/users(.*)",
            "dest": "/api/index.js"
        },
        {
            "src": "/((?!api/services|api/projects|api/users|api/index.js).*)",
            "dest": "/web/$1"
        }
    ]
}